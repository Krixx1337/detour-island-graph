@PACKAGE_INIT@

if(TARGET Detour)
    set(_detour_island_graph_detour_target Detour)
elseif(TARGET RecastNavigation::Detour)
    set(_detour_island_graph_detour_target RecastNavigation::Detour)
else()
    set(detour_island_graph_FOUND FALSE)
    set(detour_island_graph_NOT_FOUND_MESSAGE
        "Define a Detour or RecastNavigation::Detour target before finding detour_island_graph.")
    return()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/detour_island_graphTargets.cmake")
set_property(TARGET detour_island_graph::detour_island_graph APPEND PROPERTY
    INTERFACE_LINK_LIBRARIES "${_detour_island_graph_detour_target}")
unset(_detour_island_graph_detour_target)
